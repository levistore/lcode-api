    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.3",
    "pg": "^8.22.0",
